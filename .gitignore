# Lixo do Windows/Office que o git deve ignorar
Thumbs.db
desktop.ini
~$*
*.tmp

# Lixo do Python
__pycache__/
*.pyc

# SOJ Operacional (Etapa 1, 2026-07-15)
AUTOS/
RADAR/relatorios/
RADAR/.cache_datajud.json

# fixtures de teste do radar (teor real de intimacoes — dados de cliente)
RADAR/fixtures/
_SISTEMA/browser_profile/

# estado de runtime da marcha viva (fila de captura + sem-cobertura): muda a cada
# varredura, se regenera sozinho — como os logs, nao se versiona.
_SISTEMA/marcha/

# perfis de navegador nunca entram no git (e nao devem nem existir: sao efemeros)
CONECTOR/**/browser_profile/
_SISTEMA/quarentena.md.bak

# ===== CERTIFICADO DIGITAL — NUNCA no git, NUNCA no OneDrive =====
# O .pfx do A1 e a assinatura de advogado do titular: com ele e a senha,
# assina-se e peticiona-se em nome dele. Estes padroes existem para que um
# "copiei so um minuto para ca" nao vire um commit publico.
*.pfx
*.p12
*.pem
*.key
*.jks
*.keystore
certificado*

# mapeamento do painel (HTML e trafego — dado de cliente)
_efemeros/

# index de busca FTS5 — GERADO, reconstruivel, fora do Git
index/

# catalogo do motor de audio — CACHE (hash -> degravacao). E reconstruivel a
# partir dos sidecars <audio>.txt, muda a cada rodada e e binario: fora do Git.
_SISTEMA/audio/

# libs vendorizadas p/ o agendador (pyyaml/ruamel) — reinstalaveis, fora do Git
# recriar: python -m pip install --target _SISTEMA/pylibs pyyaml ruamel.yaml
_SISTEMA/pylibs/

# wrapper do agendador — GERADO por soj_agendar (caminho da python da maquina)
ESCRITORIO/scripts/soj_atualizar_agendado.cmd
