Thumbs.db
desktop.ini
~$*
*.tmp

# Lixo do Python
__pycache__/
*.pyc

# SOJ Operacional (Etapa 1, 2026-07-15)
AUTOS/
RADAR/relatorios/
RADAR/.cache_datajud.json

# fixtures de teste do radar (teor real de intimacoes — dados de cliente)
RADAR/fixtures/
